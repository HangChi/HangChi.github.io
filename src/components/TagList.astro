---
// 标签徽章：渲染一组可点击标签，链接到 /tags/<tag> 聚合页。
interface Props {
  tags: string[];
}
const { tags } = Astro.props;
---

{
  tags && tags.length > 0 && (
    <ul class="tags">
      {tags.map((tag) => (
        <li>
          <a href={`/tags/${encodeURIComponent(tag)}`}>#{tag}</a>
        </li>
      ))}
    </ul>
  )
}

<style>
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0.5rem 0;
  }
  .tags a {
    display: inline-block;
    background: var(--tag-bg);
    color: var(--tag-text);
    padding: 0.15em 0.7em;
    border-radius: 999px;
    font-size: 0.82rem;
    transition: opacity 0.15s ease;
  }
  .tags a:hover {
    text-decoration: none;
    opacity: 0.8;
  }
</style>

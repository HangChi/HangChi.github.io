---
import { SITE_TITLE } from '../consts';
import ThemeToggle from './ThemeToggle.astro';
import {
  CATEGORY_META,
  CATEGORY_ORDER,
  getCategoryPath,
} from '../utils/categories';

// 当前路径，用于高亮所在导航项（无障碍：aria-current="page"）。
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
const isArticleActive = path.startsWith('/blog') || path.startsWith('/categories');
const articleCategories = CATEGORY_ORDER.map((slug) => CATEGORY_META[slug]);
---

<header>
  <nav>
    <a href="/" class="site-title">
      <img class="logo" src="/logo.png" alt="爱达堡的技术博客" width="32" height="32" />
      <span>{SITE_TITLE}</span>
    </a>
    <div class="nav-right">
      <div class="links">
        <a
          href="/"
          class={isActive('/') ? 'active' : undefined}
          aria-current={isActive('/') ? 'page' : undefined}
        >
          首页
        </a>
        <div class="nav-item has-menu">
          <a
            href="/blog"
            class={isArticleActive ? 'active' : undefined}
            aria-current={path.startsWith('/blog') ? 'page' : undefined}
            aria-haspopup="true"
          >
            文章
          </a>
          <div class="article-menu" aria-label="文章分类">
            {
              articleCategories.map((category) => (
                <a href={getCategoryPath(category.slug)}>
                  <span>{category.name}</span>
                  <small>{category.description}</small>
                </a>
              ))
            }
          </div>
        </div>
        <a
          href="/tags"
          class={isActive('/tags') ? 'active' : undefined}
          aria-current={isActive('/tags') ? 'page' : undefined}
        >
          标签
        </a>
        <a
          href="/about"
          class={isActive('/about') ? 'active' : undefined}
          aria-current={isActive('/about') ? 'page' : undefined}
        >
          关于
        </a>
      </div>
      <ThemeToggle />
    </div>
  </nav>
</header>

<style>
  header {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 10;
    min-height: 62px;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }
  nav {
    max-width: var(--width-wide);
    margin: 0 auto;
    padding: 0.8rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 62px;
    font-family: system-ui, -apple-system, 'Segoe UI', 'Microsoft YaHei',
      sans-serif;
  }
  .site-title {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--text);
    white-space: nowrap;
  }
  .site-title .logo {
    flex-shrink: 0;
    display: block;
    border-radius: 6px;
  }
  .site-title:hover {
    text-decoration: none;
    color: var(--link);
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex: 0 0 auto;
  }
  .links {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .links > a,
  .nav-item > a {
    color: var(--text-muted);
    font-size: 0.95rem;
    min-width: 2.15rem;
    text-align: center;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition: color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }
  .links > a:hover,
  .nav-item > a:hover {
    color: var(--link);
    text-decoration: none;
  }
  /* 当前所在页：品牌蓝下划线 + 主文本色（透明边框常驻，避免位移） */
  .links > a.active,
  .nav-item > a.active {
    color: var(--text);
    border-bottom-color: var(--brand);
  }
  .nav-item {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .article-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    z-index: var(--z-overlay);
    width: 11.5rem;
    padding: 0.35rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg);
    box-shadow: 0 12px 28px var(--shadow);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translate(-50%, -4px);
    transition: opacity var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out),
      visibility var(--dur-fast) var(--ease-out);
  }
  .article-menu::before {
    content: '';
    position: absolute;
    top: -0.55rem;
    left: 0;
    right: 0;
    height: 0.55rem;
  }
  .nav-item:hover .article-menu,
  .nav-item:focus-within .article-menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translate(-50%, 0);
  }
  .article-menu a {
    display: block;
    padding: 0.5rem 0.6rem;
    border-radius: var(--radius-sm);
    color: var(--text);
  }
  .article-menu a:hover,
  .article-menu a:focus-visible {
    background: var(--bg-subtle);
    color: var(--link);
    text-decoration: none;
  }
  .article-menu span,
  .article-menu small {
    display: block;
  }
  .article-menu span {
    font-size: 0.9rem;
    line-height: 1.35;
  }
  .article-menu small {
    margin-top: 0.12rem;
    color: var(--text-muted);
    font-size: 0.74rem;
    line-height: 1.35;
  }

  /* 平板：收紧导航间距与内边距 */
  @media (max-width: 768px) {
    header,
    nav {
      min-height: 58px;
    }
    nav {
      padding: 0.7rem 1.1rem;
    }
    .nav-right {
      gap: 0.8rem;
    }
    .links {
      gap: 0.9rem;
    }
  }

  /* 手机：导航换成两行——标题一行，菜单+主题钮一行并居中 */
  @media (max-width: 480px) {
    header,
    nav {
      min-height: 94px;
    }
    nav {
      flex-direction: column;
      gap: 0.6rem;
      padding: 0.7rem 1rem;
    }
    .nav-right {
      width: 100%;
      justify-content: space-between;
    }
    .site-title {
      font-size: 1.05rem;
    }
    .links {
      gap: 0.95rem;
    }
    .links > a,
    .nav-item > a {
      font-size: 0.9rem;
      min-width: 2rem;
      /* 增大触屏可点击区域 */
      padding: 0.3rem 0;
      display: inline-block;
    }
    .article-menu {
      left: auto;
      right: -2.4rem;
      transform: translate(0, -4px);
    }
    .nav-item:hover .article-menu,
    .nav-item:focus-within .article-menu {
      transform: translate(0, 0);
    }
  }
</style>

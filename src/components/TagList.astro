---
// 标签徽章：渲染一组可点击标签，链接到 /tags/<tag> 聚合页。
interface Props {
  tags: string[];
}
const { tags } = Astro.props;
---

{
  tags && tags.length > 0 && (
    <ul class="tags">
      {tags.map((tag) => (
        <li>
          <a href={`/tags/${encodeURIComponent(tag)}`}>#{tag}</a>
        </li>
      ))}
    </ul>
  )
}

<style>
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 0.9rem;
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
  }
  .tags li {
    margin: 0;
  }
  /* 标签作为安静的元信息：无填充胶囊，仅淡色文字，悬停才点亮 */
  .tags a {
    display: inline-block;
    color: var(--text-muted);
    font-size: var(--text-xs);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .tags a:hover {
    text-decoration: none;
    color: var(--link);
  }
</style>

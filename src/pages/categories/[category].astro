---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import TagList from '../../components/TagList.astro';
import {
  CATEGORY_META,
  CATEGORY_ORDER,
  comparePostsByPriority,
  getPostCategorySlug,
  type CategoryInfo,
} from '../../utils/categories';

type BlogPost = CollectionEntry<'blog'>;

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft);

  return CATEGORY_ORDER.map((slug) => {
    const filtered = posts
      .filter((post) => getPostCategorySlug(post) === slug)
      .sort(comparePostsByPriority);

    return {
      params: { category: slug },
      props: {
        category: CATEGORY_META[slug],
        posts: filtered,
      },
    };
  }).filter(({ props }) => props.posts.length > 0);
}

const { category, posts } = Astro.props as {
  category: CategoryInfo;
  posts: BlogPost[];
};
---

<Layout
  title={`分类：${category.name}`}
  description={`${category.name} 下的全部文章`}
  wide
>
  <p class="back"><a href="/categories">← 所有分类</a></p>
  <h1>{category.name}</h1>
  <p class="description">{category.description}</p>
  <p class="count">共 {posts.length} 篇文章</p>

  <ul class="post-list">
    {
      posts.map((post) => (
        <li>
          <div class="post-date">
            {post.data.pinned && <span class="pin-flag">置顶</span>}
            <FormattedDate date={post.data.pubDate} compact />
          </div>
          <div class="post-body">
            <a class="post-link" href={`/blog/${post.id}/`}>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="desc">{post.data.description}</p>
            </a>
            <TagList tags={post.data.tags} />
          </div>
        </li>
      ))
    }
  </ul>
</Layout>

<style>
  .back a {
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .description {
    color: var(--text-muted);
    margin: -0.3rem 0 0.2rem;
  }
  .count {
    color: var(--text-muted);
    margin-top: 0;
  }
  .post-list {
    margin-top: 1.5rem;
  }
</style>

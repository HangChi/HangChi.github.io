---
import type { GetStaticPaths, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import TagList from '../../components/TagList.astro';

// 分页：第一页为 /blog，后续为 /blog/2、/blog/3……
export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getCollection('blog'))
    .filter((p) => !p.data.draft)
    .sort((a, b) => {
      // 置顶优先，再按发布日期降序
      if (!!a.data.pinned !== !!b.data.pinned) return a.data.pinned ? -1 : 1;
      return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
    });
  return paginate(posts, { pageSize: 12 });
}) satisfies GetStaticPaths;

const { page } = Astro.props as { page: Page<CollectionEntry<'blog'>> };
---

<Layout
  title={`全部文章 · 第 ${page.currentPage}/${page.lastPage} 页`}
  description="文章归档列表"
  wide
>
  <h1>全部文章</h1>
  <p class="count">共 {page.total} 篇 · 第 {page.currentPage} / {page.lastPage} 页</p>

  <ul class="post-list">
    {
      page.data.map((post) => (
        <li>
          <div class="post-date">
            {post.data.pinned && <span class="pin-flag">置顶</span>}
            <FormattedDate date={post.data.pubDate} compact />
          </div>
          <div class="post-body">
            <a class="post-link" href={`/blog/${post.id}/`}>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="desc">{post.data.description}</p>
            </a>
            <TagList tags={post.data.tags} />
          </div>
        </li>
      ))
    }
  </ul>

  {
    page.lastPage > 1 && (
      <nav class="pagination" aria-label="分页">
        {page.url.prev ? (
          <a class="page-btn" href={page.url.prev}>
            ← 上一页
          </a>
        ) : (
          <span class="page-btn disabled">← 上一页</span>
        )}

        <span class="page-info">
          {page.currentPage} / {page.lastPage}
        </span>

        {page.url.next ? (
          <a class="page-btn" href={page.url.next}>
            下一页 →
          </a>
        ) : (
          <span class="page-btn disabled">下一页 →</span>
        )}
      </nav>
    )
  }
</Layout>

<style>
  .count {
    color: var(--text-muted);
    margin-top: -0.5rem;
  }
  .post-list {
    margin-top: 1.5rem;
  }

  /* 分页导航 */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2.2rem;
  }
  .page-btn {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.45rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text);
    font-size: var(--text-sm);
    white-space: nowrap;
    transition: background-color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }
  .page-btn:hover {
    text-decoration: none;
    background: var(--bg-subtle);
    border-color: var(--brand);
  }
  .page-btn.disabled {
    color: var(--text-muted);
    opacity: 0.45;
    pointer-events: none;
  }
  .page-info {
    color: var(--text-muted);
    font-size: 0.9rem;
    font-variant-numeric: tabular-nums;
  }
</style>

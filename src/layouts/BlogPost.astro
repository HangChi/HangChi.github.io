---
// 文章详情布局：标题、元信息、标签、正文、评论。
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TagList from '../components/TagList.astro';
import Comments from '../components/Comments.astro';
// KaTeX 数学公式样式（题解里的 $O(n)$ 等公式渲染所需）
import 'katex/dist/katex.min.css';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } =
  Astro.props;
---

<Layout title={title} description={description} image={heroImage} wide>
  <article>
    {heroImage && <img class="hero" src={heroImage} alt="" />}
    <header class="post-header">
      <h1>{title}</h1>
      <div class="meta">
        <FormattedDate date={pubDate} />
        {
          updatedDate && (
            <span class="updated">
              （更新于 <FormattedDate date={updatedDate} />）
            </span>
          )
        }
      </div>
      <TagList tags={tags} />
    </header>

    <div class="content">
      <slot />
    </div>

    <Comments />
  </article>
</Layout>

<style>
  .hero {
    width: 100%;
    max-height: 360px;
    object-fit: cover;
    margin-bottom: 1.5rem;
  }
  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.2rem;
    border-bottom: 1px solid var(--border);
  }
  .post-header h1 {
    margin: 0 0 0.5rem;
    font-size: 2.2rem;
  }
  .meta {
    color: var(--text-muted);
    font-size: var(--text-sm);
    margin-bottom: 0.6rem;
  }
  .updated {
    font-style: italic;
  }

  /* 正文：略大字号，配合加宽后的版心更耐读 */
  .content {
    font-size: 1.05rem;
  }
  /* 长技术文章：给 h2 一条淡分隔线，便于扫读分段 */
  .content :global(h2) {
    padding-bottom: 0.3em;
    border-bottom: 1px solid var(--border);
  }
  /* 锚点跳转时，标题不被 sticky 顶栏遮挡 */
  .content :global(:is(h1, h2, h3, h4)) {
    scroll-margin-top: 5rem;
  }

  /* 文章正文里的宽表格：窄屏可横向滚动，不撑破版面 */
  .content :global(table) {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    white-space: nowrap;
  }

  /* 文章页响应式 */
  @media (max-width: 768px) {
    .post-header h1 {
      font-size: 1.8rem;
    }
    .content {
      font-size: 1.02rem;
    }
    .hero {
      max-height: 240px;
      margin-bottom: 1.2rem;
    }
    .post-header {
      margin-bottom: 1.5rem;
    }
    .content :global(table) {
      font-size: 0.88rem;
    }
    .content :global(th),
    .content :global(td) {
      padding: 0.4em 0.6em;
    }
  }
</style>

---
/*
  Giscus 评论组件（基于 GitHub Discussions，免费无广告）。

  配置在 src/consts.ts 的 GISCUS 对象里，按 SETUP.md 第 4 节填入
  repoId / categoryId 即可启用。未配置时显示友好提示，不影响其他功能。

  特性：
  - 懒加载：滚动到评论区附近才加载 giscus，首屏更快、更省流量。
  - 主题联动：跟随站点深色模式（监听 theme-change 事件）。
*/
import { GISCUS } from '../consts';
---

<section class="comments" aria-label="评论">
  <h2>评论</h2>
  <div id="giscus-container"></div>
</section>

<script is:inline define:vars={{ GISCUS }}>
  // 根据当前站点主题决定 giscus 主题
  function currentGiscusTheme() {
    return document.documentElement.classList.contains('dark')
      ? 'dark'
      : 'light';
  }

  function injectGiscus() {
    const container = document.getElementById('giscus-container');
    if (!container || container.dataset.loaded) return;

    // 未配置真实 ID 时给出友好提示，避免空白。
    // repoId 或 categoryId 任一仍是占位符，都视为未配置。
    if (
      GISCUS.repoId.startsWith('REPLACE_') ||
      GISCUS.categoryId.startsWith('REPLACE_')
    ) {
      container.innerHTML =
        '<p style="color:var(--text-muted);font-size:0.9rem">' +
        '💬 评论区尚未配置。请按 SETUP.md 第 4 节在 src/consts.ts 填入 giscus 信息。</p>';
      container.dataset.loaded = '1';
      return;
    }

    const s = document.createElement('script');
    s.src = 'https://giscus.app/client.js';
    s.setAttribute('data-repo', GISCUS.repo);
    s.setAttribute('data-repo-id', GISCUS.repoId);
    s.setAttribute('data-category', GISCUS.category);
    s.setAttribute('data-category-id', GISCUS.categoryId);
    s.setAttribute('data-mapping', 'pathname');
    s.setAttribute('data-strict', '0');
    s.setAttribute('data-reactions-enabled', '1');
    s.setAttribute('data-emit-metadata', '0');
    s.setAttribute('data-input-position', 'top');
    s.setAttribute('data-theme', currentGiscusTheme());
    s.setAttribute('data-lang', 'zh-CN');
    s.setAttribute('data-loading', 'lazy');
    s.setAttribute('crossorigin', 'anonymous');
    s.async = true;
    container.appendChild(s);
    container.dataset.loaded = '1';
  }

  // 懒加载：评论区进入视口（提前 200px）再注入 giscus。
  function setupLazyLoad() {
    const container = document.getElementById('giscus-container');
    if (!container) return;

    if (!('IntersectionObserver' in window)) {
      injectGiscus(); // 不支持时直接加载
      return;
    }
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries.some((e) => e.isIntersecting)) {
          injectGiscus();
          observer.disconnect();
        }
      },
      { rootMargin: '200px' }
    );
    observer.observe(container);
  }

  setupLazyLoad();

  // 站点切换主题时，向 giscus iframe 发送 postMessage 同步主题
  window.addEventListener('theme-change', (e) => {
    const theme = e.detail?.theme || currentGiscusTheme();
    const iframe = document.querySelector('iframe.giscus-frame');
    iframe?.contentWindow?.postMessage(
      { giscus: { setConfig: { theme } } },
      'https://giscus.app'
    );
  });
</script>

<style>
  .comments {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .comments h2 {
    font-size: 1.3rem;
    margin-top: 0;
  }
</style>

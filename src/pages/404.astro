---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 · 页面未找到" description="页面未找到">
  <div class="notfound">
    <h1>404</h1>
    <p>抱歉，这个页面不存在。</p>
    <a href="/">← 返回首页</a>
  </div>
</Layout>

<style>
  .notfound {
    text-align: center;
    padding: 4rem 0;
  }
  .notfound h1 {
    font-size: 4rem;
    margin: 0 0 0.5rem;
    /* 品牌渐变数字，作为空页面上的克制点缀 */
    background: linear-gradient(135deg, var(--brand-cyan), var(--brand));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  @media (max-width: 480px) {
    .notfound {
      padding: 2.5rem 0;
    }
    .notfound h1 {
      font-size: 2.8rem;
    }
  }
</style>

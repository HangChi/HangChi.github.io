---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 · 页面未找到" description="页面未找到">
  <div class="notfound">
    <h1>404</h1>
    <p>抱歉，这个页面不存在。</p>
    <a href="/">← 返回首页</a>
  </div>
</Layout>

<style>
  .notfound {
    text-align: center;
    padding: 4rem 0;
  }
  .notfound h1 {
    font-size: 4rem;
    margin: 0;
    color: var(--text-muted);
  }
</style>

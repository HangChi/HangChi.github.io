---
import { SITE_TITLE } from '../consts';
import ThemeToggle from './ThemeToggle.astro';

// 当前路径，用于高亮所在导航项（无障碍：aria-current="page"）。
const path = Astro.url.pathname;
const links = [
  { href: '/', label: '首页' },
  { href: '/blog', label: '文章' },
  { href: '/tags', label: '标签' },
  { href: '/about', label: '关于' },
];
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header>
  <nav>
    <a href="/" class="site-title">
      <img class="logo" src="/logo.png" alt="爱达堡的技术博客" width="32" height="32" />
      <span>{SITE_TITLE}</span>
    </a>
    <div class="nav-right">
      <div class="links">
        {
          links.map((l) => (
            <a
              href={l.href}
              class={isActive(l.href) ? 'active' : undefined}
              aria-current={isActive(l.href) ? 'page' : undefined}
            >
              {l.label}
            </a>
          ))
        }
      </div>
      <ThemeToggle />
    </div>
  </nav>
</header>

<style>
  header {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 10;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }
  nav {
    max-width: var(--width-wide);
    margin: 0 auto;
    padding: 0.8rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .site-title {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--text);
  }
  .site-title .logo {
    flex-shrink: 0;
    display: block;
    border-radius: 6px;
  }
  .site-title:hover {
    text-decoration: none;
    color: var(--link);
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .links {
    display: flex;
    gap: 1.1rem;
  }
  .links a {
    color: var(--text-muted);
    font-size: 0.95rem;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition: color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }
  .links a:hover {
    color: var(--link);
    text-decoration: none;
  }
  /* 当前所在页：品牌蓝下划线 + 主文本色（透明边框常驻，避免位移） */
  .links a.active {
    color: var(--text);
    border-bottom-color: var(--brand);
  }

  /* 平板：收紧导航间距与内边距 */
  @media (max-width: 768px) {
    nav {
      padding: 0.7rem 1.1rem;
    }
    .nav-right {
      gap: 0.8rem;
    }
    .links {
      gap: 0.9rem;
    }
  }

  /* 手机：导航换成两行——标题一行，菜单+主题钮一行并居中 */
  @media (max-width: 480px) {
    nav {
      flex-direction: column;
      gap: 0.6rem;
      padding: 0.7rem 1rem;
    }
    .nav-right {
      width: 100%;
      justify-content: space-between;
    }
    .site-title {
      font-size: 1.05rem;
    }
    .links {
      gap: 1.2rem;
    }
    .links a {
      font-size: 0.9rem;
      /* 增大触屏可点击区域 */
      padding: 0.3rem 0;
      display: inline-block;
    }
  }
</style>

---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TagList from '../components/TagList.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

// 取所有非草稿文章：置顶优先，再按发布日期降序，首页展示最近 9 篇。
const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => {
    if (!!a.data.pinned !== !!b.data.pinned) return a.data.pinned ? -1 : 1;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  });

const recent = posts.slice(0, 9);
---

<Layout wide>
  <section class="hero">
    <h1>{SITE_TITLE}</h1>
    <p>{SITE_DESCRIPTION}</p>
  </section>

  <section class="recent">
    <div class="section-head">
      <h2>最新文章</h2>
      <a href="/blog">全部 →</a>
    </div>

    {posts.length === 0 && <p class="empty">还没有文章，快去 src/content/blog 写第一篇吧！</p>}

    <ul class="post-list">
      {
        recent.map((post) => (
          <li>
            <a class="post-link" href={`/blog/${post.id}/`}>
              <h3>
                {post.data.pinned && <span class="pin-badge">📌 置顶</span>}
                {post.data.title}
              </h3>
              <p class="desc">{post.data.description}</p>
            </a>
            <div class="post-meta">
              <FormattedDate date={post.data.pubDate} />
              <TagList tags={post.data.tags} />
            </div>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 3.5rem 0 2.5rem;
  }
  .hero h1 {
    margin: 0 0 0.5rem;
    font-size: 2.6rem;
  }
  .hero p {
    color: var(--text-muted);
    font-size: 1.1rem;
    margin: 0;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
  }
  .section-head h2 {
    margin: 0;
  }
  .section-head a {
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .empty {
    color: var(--text-muted);
  }
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post-list li {
    padding: 1.2rem 0;
    border-bottom: 1px solid var(--border);
  }
  /* 去掉最后一项的分隔线，避免底部出现孤立横线 */
  .post-list li:last-child {
    border-bottom: none;
  }
  .post-link h3 {
    margin: 0 0 0.3rem;
    color: var(--text);
  }
  .pin-badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--tag-text);
    background: var(--tag-bg);
    padding: 0.1em 0.55em;
    border-radius: 999px;
    margin-right: 0.45em;
    vertical-align: middle;
  }
  .post-link:hover h3 {
    color: var(--link);
  }
  .post-link:hover {
    text-decoration: none;
  }
  .desc {
    color: var(--text-muted);
    margin: 0 0 0.5rem;
    font-size: 0.95rem;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  /* 平板：hero 适度缩小 */
  @media (max-width: 768px) {
    .hero {
      padding: 2.5rem 0 1.8rem;
    }
    .hero h1 {
      font-size: 2.1rem;
    }
    .hero p {
      font-size: 1rem;
    }
  }

  /* 手机：hero 再收紧 */
  @media (max-width: 480px) {
    .hero {
      padding: 1.8rem 0 1.4rem;
    }
    .hero h1 {
      font-size: 1.7rem;
    }
  }
</style>
